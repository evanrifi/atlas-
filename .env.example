# ─────────────────────────────────────────
#   Atlas Unit — Environment Variables
# ─────────────────────────────────────────

DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# ── GIF Banner ───────────────────────────
# Upload atlas-unit-banner.gif to any channel in Discord
# Right-click the image → Copy Link → paste here
BANNER_GIF_URL=https://cdn.discordapp.com/attachments/YOUR_CHANNEL/YOUR_FILE/atlas-unit-banner.gif

# ── Join-to-Create Channels ──────────────
JOIN_TO_CREATE_ID=your_default_jtc_id_here
JTC_GAMING=your_gaming_jtc_id_here
JTC_STUDY=your_study_jtc_id_here
JTC_MUSIC=your_music_jtc_id_here
JTC_CHILL=your_chill_jtc_id_here
