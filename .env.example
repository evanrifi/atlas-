# Required — bot login and command registration
DISCORD_TOKEN=
CLIENT_ID=
# Server where slash commands are registered — must match the server you test in (Developer Mode → Copy Server ID)
GUILD_ID=

# After editing slash commands, run: npm run deploy
# CLIENT_ID must be the same app as DISCORD_TOKEN (deploy script checks this).

# Join-to-create voice channel IDs (create channels in Discord, then paste IDs here)
# At minimum set JOIN_TO_CREATE_ID; optional themed hubs:
JOIN_TO_CREATE_ID=
JTC_GAMING=
JTC_STUDY=
JTC_MUSIC=
JTC_CHILL=

# Optional — panel embed image (HTTPS URL)
BANNER_GIF_URL=

# Optional — XP level-up announcements (channel ID) and milestone roles
LEVEL_UP_CHANNEL_ID=
ROLE_LEVEL_5=
ROLE_LEVEL_10=
ROLE_LEVEL_20=
ROLE_LEVEL_50=

# Optional — automod / manual warn logs
MOD_LOG_CHANNEL_ID=

# Welcome (Probot-style) — requires Server Members Intent in Discord Developer Portal
WELCOME_CHANNEL_ID=
# Optional: logo URL for embed author (recommended: host your ATLAS UNIT logo on a CDN or Discord)
WELCOME_LOGO_URL=
# Optional: wide banner under the text (HTTPS URL)
WELCOME_BANNER_URL=
# Optional: embed accent (hex without # or with #)
WELCOME_COLOR=00E5FF
# Optional: title/body (placeholders: {user} {username} {usertag} {mention} {server} {memberCount} {created} {createdRelative})
# WELCOME_TITLE=
# WELCOME_BODY=
# Or drop a file at assets/welcome-logo.png (used if WELCOME_LOGO_URL is unset)

# Role panels (dropdowns, Boom Bot style) — copy data/role-panels.example.json → data/role-panels.json
# Set your GUILD_ID and each role ID, then: /roles post (Administrator) in your roles channel

# Nitro server boost — thank-you message (uses guildMemberUpdate)
# If unset, falls back to WELCOME_CHANNEL_ID. Set a dedicated channel for boost-only logs.
BOOST_LOG_CHANNEL_ID=
# Embed color (hex, no # ok) — default nitro pink ff73fa
BOOST_COLOR=ff73fa
# Set to 0 or false to send the embed without pinging the booster
BOOST_PING_USER=1
# Optional custom body — {user} {username} {mention} {server} {boostCount} {tier}
# BOOST_MESSAGE=
